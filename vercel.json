{
  "version": 2,
  "builds": [
    {
      "src": "Frontend/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "Frontend/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "Frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Frontend/index.html"
    }
  ]
}
